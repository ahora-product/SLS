{
  "name": "correduria-seguros-static",
  "version": "1.0.0",
  "private": true,
  "description": "Web estática para correduría de seguros (Tailwind + Flowbite)",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./assets/css/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./assets/css/output.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "flowbite": "^2.5.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15"
  }
}
